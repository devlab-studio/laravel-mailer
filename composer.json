{
    "name": "devlab-studio/laravel-mailer",
    "description": "This is my package laravel-mailer",
    "keywords": [
        "Devlab",
        "laravel",
        "laravel-mailer"
    ],
    "homepage": "https://github.com/devlab-studio/laravel-mailer",
    "license": "MIT",
    "authors": [
        {
            "name": "Devlab",
            "email": "david.maizcurrana@dev-lab.es",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "livewire/livewire": "^4.0",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^11.0||^12.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^10.0.0||^9.0.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Devlab\\LaravelMailer\\": "src/",
            "Devlab\\LaravelMailer\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Devlab\\LaravelMailer\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Devlab\\LaravelMailer\\LaravelMailerServiceProvider"
            ],
            "aliases": {
                "LaravelMailer": "Devlab\\LaravelMailer\\Facades\\LaravelMailer"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
